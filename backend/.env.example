# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# ── Banco de dados ────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=acsexpert

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=troque-por-uma-chave-secreta-forte
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=troque-por-outra-chave-secreta
JWT_REFRESH_EXPIRES_IN=7d

# ── Servidor ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
